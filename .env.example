DEEPGRAM_API_KEY=your-deepgram-key
GEMINI_API_KEY=your-gemini-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
# Optional: the single admin account allowed to skip scenarios for testing.
# Server-side check only; empty (or unset) means no one is admin.
ADMIN_EMAIL=you@example.com
# Optional pronunciation scoring (Azure Speech). Leave blank to disable.
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus2
# Production only: point this at the Railway volume mount.
VOICE_AUDIO_DIR=/data/voice-audio
